<ui:ContentDialog x:Class="MultiDesktopAdaptor.CommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Add Command"
        PrimaryButtonText="Save"
        SecondaryButtonText="Cancel"
        DefaultButton="Primary">
    <Grid Width="420" Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Title (optional, shown in menu)" Margin="0,0,0,4" />
        <TextBox x:Name="TitleTextBox" Grid.Row="1" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="Command Line (use $VarName for variables)" Margin="0,0,0,4" />
        <TextBox x:Name="CommandLineTextBox" Grid.Row="3"
                 AcceptsReturn="True" Height="60" />

        <TextBlock x:Name="ValidationErrorText" Grid.Row="4"
                   Foreground="Red" Visibility="Collapsed"
                   Margin="0,6,0,0" />
    </Grid>
</ui:ContentDialog>
