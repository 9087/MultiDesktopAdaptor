<ui:ContentDialog x:Class="MultiDesktopAdaptor.CommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Add Command"
        PrimaryButtonText="Save"
        SecondaryButtonText="Cancel"
        DefaultButton="Primary">
    <Grid Width="480" Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MaxHeight="240" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Title (shown in tray menu)" Margin="0,0,0,4" />
        <TextBox x:Name="TitleTextBox" Grid.Row="1" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

        <TextBlock x:Name="ValidationErrorText" Grid.Row="2"
                   Foreground="Red" Visibility="Collapsed"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="3" Text="Per-desktop command lines (absolute paths required):"
                   Margin="0,0,0,4" />
        <ItemsControl x:Name="DesktopCommandsList" Grid.Row="4"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DesktopName}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 HorizontalAlignment="Stretch"
                                 Text="{Binding CommandLine, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</ui:ContentDialog>
