<ui:ContentDialog x:Class="MultiDesktopAdaptor.WindowRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Add Window Rule"
        PrimaryButtonText="Save"
        SecondaryButtonText="Cancel"
        DefaultButton="Primary">
    <Grid Width="420" Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Window Title" Margin="0,0,0,4" />
        <ComboBox x:Name="WindowTitleComboBox" Grid.Row="1"
                  IsEditable="True" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="Window Class" Margin="0,0,0,4" />
        <ComboBox x:Name="WindowClassComboBox" Grid.Row="3"
                  IsEditable="True" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

        <TextBlock Grid.Row="4" Text="Process Name" Margin="0,0,0,4" />
        <ComboBox x:Name="ProcessNameComboBox" Grid.Row="5"
                  IsEditable="True" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

        <StackPanel Grid.Row="6">
            <Button Content="Flash Matches" Width="110"
                    HorizontalAlignment="Left" Click="OnFlashMatchesClick" />
            <TextBlock x:Name="StatusText"
                       Foreground="Red" Visibility="Collapsed"
                       Margin="0,6,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</ui:ContentDialog>
